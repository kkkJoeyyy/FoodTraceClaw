# LLM Provider: openai | ollama
LLM_PROVIDER=openai

# OpenAI-compatible API (OpenAI / DashScope / 其他兼容服务)
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# 示例：使用阿里云百炼 DashScope + 千问
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_MODEL=qwen3.5-omni-plus-2026-03-15
# VL_MODEL=qwen3.5-omni-plus-2026-03-15

# Ollama (local)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# VL Model (uses same provider/API, specify VL-capable model)
VL_MODEL=gpt-4o

# Geocoding: osm | amap
GEOCODE_PROVIDER=osm
# AMAP_API_KEY=your-amap-key  # only if GEOCODE_PROVIDER=amap

# WeChat Bot (wechaty bridge)
# WECHATY_PUPPET=wechaty-puppet-wechat4u
# BACKEND_URL=http://localhost:8000
